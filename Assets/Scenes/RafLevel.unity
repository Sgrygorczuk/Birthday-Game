--- !u!1001 &5344742991185537936
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 1224224317435694482, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: m_Sprite
      value: 
      objectReference: {fileID: 21300000, guid: aa56fc83fdbf5054eab6eb887ab561b6, type: 3}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.size
      value: 10
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[0]
      value: 'Raf: Hello Friend, Welcome to my Peaceful Land '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[1]
      value: 'Snake: Psstt Peaceful land not pssstt I am here to bring you back to
        reality'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[2]
      value: 'Raf: As long as we have faith, trust and pixie dust we can conquer
        anything!'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[3]
      value: 'Snake: Psstt eyyy positive one here eyy my fave kind of pssst meals..'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[4]
      value: 'Raf: Don''t step any closer you damnn peasent snake!'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[5]
      value: 'Snake: Psstt Challenge Accepted psstt wait till I chow down on that
        little tail of yours.'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[6]
      value: 'Raf: Feel the heat of my trash you piece of snake issh!!!'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[7]
      value: 'Snake: Psstt nooo psstt noo my only weakness the trash of my enemies
        psstt I''m dyinggg!!'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[8]
      value: 'Raf: Time to take out the trash, once a piece of trash always a piece
        of garbage..'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[9]
      value: 'Raf: Now where''s Pres, it''s time for hobby time!'
      objectReference: {fileID: 0}
    - target: {fileID: 2741854173681740130, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: m_LocalPosition.x
