--- !u!1001 &360503049
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 1224224317435694482, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: m_Sprite
      value: 
      objectReference: {fileID: 21300000, guid: ce40b352766a4cf4fbd11c4a8e58de67, type: 3}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.size
      value: 14
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[0]
      value: 'Raf: Hello Friend, Welcome to my Peaceful Land '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[1]
      value: 'Bird: Peaceful land more like boringgg!!'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[2]
      value: 'Raf: Bird, where are you from, be gone from my land..'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[3]
      value: 'Bird: It''s a snoozefest, where''s the tall buildings, I like to see
        my handsome reflection when I sore the sky.'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[4]
      value: 'Raf: Can''t believe you can take off with an ego that big!'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[5]
      value: 'Bird: Brr enough small talk, ready to face my wrath cozy "Queen".'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[6]
      value: 'Raf: I don''t know if you want to go up against me, I trashed the other
        guy! '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[7]
      value: 'Bird: A puny girl like you I can take, easy peasy.'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[8]
      value: 'Raf: If you say so, time to take out the trash!!'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[9]
      value: 'Bird: What is with you and trash jeezzz, wait nooo what!!! '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[10]
      value: 'Bird: My wings are stuck, I can''t move I can''t fly, I''m stuck here.'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[11]
      value: 'Raf: Ohh I thought one shot would be enoughh hmm seems like I need
        to send more your way..'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[12]
      value: 'Bird: I can''t I can''t breathe I can''t... '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[13]
      value: 'Raf: Yeah peace and quiet on my cozy land, now where''s Pres he needs
        to do his chores! '
      objectReference: {fileID: 0}
    - target: {fileID: 2741854173681740130, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: m_LocalPosition.x
      value: 15.4
      objectReference: {fileID: 0}
    - target: {fileID: 2741854173681740130, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: m_LocalPosition.y
